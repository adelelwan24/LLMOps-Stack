# =============================================================================
# CPU vLLM stack — local model, no GPU
# Usage:
#   cp .env.cpu.example .env
#   docker compose -f docker-compose.cpu.yml up -d
# =============================================================================

# --- Model (local download) ---------------------------------------------------
# Hugging Face repo id used as the served model name in the OpenAI API
MODEL_HF_NAME=google/gemma-4-E4B-it

# Host path to the pre-downloaded model weights
MODEL_HOST_DIR=/opt/models/gemma-blob-files/gemma-4-E4B-it

# Mount point inside the vLLM container (must match --model path)
MODEL_CONTAINER_DIR=/models/gemma-4-E4B-it

# --- vLLM runtime -------------------------------------------------------------
VLLM_RUNTIME=cpu
VLLM_IMAGE=public.ecr.aws/q9t5s3a7/vllm-cpu-release-repo:v0.20.1

# External port exposed by Nginx (vLLM stays internal on :8000)
VLLM_PORT=8000

VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=2
VLLM_TENSOR_PARALLEL_SIZE=1

# --- CPU resource limits ------------------------------------------------------
# VLLM_CPUS=0 lets Docker use all host CPUs (omit cpus in compose if unsupported)
VLLM_CPUS=0
VLLM_MEM_LIMIT=74g
VLLM_SHM_SIZE=8g

# vLLM CPU backend tuning
VLLM_CPU_KVCACHE_SPACE=8
VLLM_CPU_NUM_OF_RESERVED_CPU=1

# --- Device selection (unused when VLLM_RUNTIME=cpu) --------------------------
# gpu  -> all or comma-separated NVIDIA GPU IDs, e.g. 0 or 0,1
# rocm -> comma-separated ROCm GPU IDs
VLLM_DEVICES=0

# --- Client / observability ---------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
BEARER_TOKEN=ML expert rules
NGINX_BASE_URL=http://localhost:8000/v1

# LangChain client reads this as the model name (must match MODEL_HF_NAME)
VLLM_MODEL_NAME=google/gemma-4-E4B-it
