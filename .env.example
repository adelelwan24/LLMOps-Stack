# =============================================================================
# LLMOps Stack — environment template
# Copy to .env and adjust for your runtime (gpu / cpu / rocm).
#
# Deploy:
#   GPU:   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
#   CPU:   docker compose -f docker-compose.yml -f docker-compose.cpu.yml up -d
#   ROCm:  docker compose -f docker-compose.yml -f docker-compose.rocm.yml up -d
# =============================================================================

# --- Model (shared) -----------------------------------------------------------
# Hugging Face repo ID — downloaded once into huggingface_cache volume, reused on restart
VLLM_MODEL=Qwen/Qwen2.5-0.5B
# OpenAI API model name sent by clients
VLLM_SERVED_MODEL_NAME=qwen-0.5b

# Hugging Face token (required for gated models; optional for Qwen2.5-0.5B)
# Set once here. Compose injects the same value as both HF_TOKEN and
# HUGGING_FACE_HUB_TOKEN inside the container (library name compatibility).
HF_TOKEN=

# External port exposed by Nginx (vLLM stays internal on :8000)
VLLM_PORT=8000

# --- GPU overrides (docker-compose.gpu.yml) ---------------------------------
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=4096

# --- CPU overrides (docker-compose.cpu.yml) ---------------------------------
VLLM_IMAGE=public.ecr.aws/q9t5s3a7/vllm-cpu-release-repo:v0.20.1
VLLM_DTYPE=bfloat16
VLLM_MAX_NUM_SEQS=2
VLLM_CPUS=0
VLLM_MEM_LIMIT=16g
VLLM_SHM_SIZE=4g
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_NUM_OF_RESERVED_CPU=1
# CPU uses a smaller context window by default (override VLLM_MAX_MODEL_LEN above if needed)

# --- ROCm overrides (docker-compose.rocm.yml) -------------------------------
VLLM_ROCM_USE_AITER=1

# --- Optional: air-gapped bind-mount (advanced) -------------------------------
# Default path uses huggingface_cache volume. For pre-downloaded local weights,
# add a bind-mount to docker-compose.cpu.yml (or a local override file):
#   MODEL_HOST_DIR=/path/on/host
#   MODEL_CONTAINER_DIR=/models/my-model
# Then set VLLM_MODEL to MODEL_CONTAINER_DIR in your override.

# --- Client / observability ---------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
BEARER_TOKEN=ML expert rules
NGINX_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=qwen-0.5b
